# ---- mediacleanuparr environment ----
# Almost nothing is configured here. Everything functional — Radarr/Sonarr URLs
# and API keys, the OMDb key, the rating threshold, scan scope, and the safety
# switches — is set in the web UI (Setup tab) and stored in /config.
#
# The only two things you set at deploy time:
#   1. APP_PORT below — the web UI port.
#   2. The media path — set via the volume mount in docker-compose.yml, by
#      mapping your host media folder to /media (NOT a variable here).

# Web UI port
APP_PORT=8787

# (Advanced/optional) PUID, PGID, UMASK, and TZ have sensible Unraid defaults
# baked into the image (99 / 100 / 002 / America/Edmonton). Override them here
# only if you have a specific reason.
